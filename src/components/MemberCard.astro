---
import type { Member } from "../data/members";

interface Props {
  member: Member;
}
const { member: m } = Astro.props;

const words = m.name.split(/\s+/).filter(Boolean);
const initials = (
  (words[0]?.[0] ?? "") + (words.length > 1 ? (words[words.length - 1]?.[0] ?? "") : "")
).toUpperCase();

const cropStyle = m.crop
  ? `--slot-s:${m.crop.s};--slot-x:${m.crop.x};--slot-y:${m.crop.y}`
  : undefined;

const Tag = m.linkedin ? "a" : "div";
const linkProps = m.linkedin
  ? { href: m.linkedin, target: "_blank", rel: "noopener", style: "text-decoration:none" }
  : {};
---

<Tag class="member" {...linkProps}>
  <div class="ph" style="padding:0">
    {m.photo
      ? <img src={m.photo} alt={m.name} loading="lazy" style={cropStyle} />
      : <span class="initials">{initials}</span>}
  </div>
  <div class="meta">
    <div class="name">{m.name}</div>
    <div class="role">{m.role}</div>
    <div class="dept">{m.dept}</div>
    {m.linkedin && <span class="li-link">LinkedIn ↗</span>}
  </div>
</Tag>
